# FRED API key (gratis, instant): https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# AlphaVantage News Sentiment (gratis, 25 req/dia): https://www.alphavantage.co/support/#api-key
ALPHA_API_KEY=

# Servidor (no cambiar salvo conflicto de puerto)
HOST=127.0.0.1
PORT=8000

# Seguridad opcional para exponer el endpoint /mt4/*
MT4_API_KEY=

# Ventanas de bloqueo para operar alrededor de noticias
BLOCK_HIGH_IMPACT_MINUTES=30
BLOCK_MEDIUM_IMPACT_MINUTES=15

# Escalado para convertir COT a sesgo [-1, +1]
COT_BIAS_DIVISOR=150000
